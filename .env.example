# Copy this file to .env and fill in real values.
# .env is gitignored — this template is safe to commit.

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key_here

# Analytics — Mixpanel (public project token)
# Get from: mixpanel.com → Project Settings → Project Token
EXPO_PUBLIC_MIXPANEL_TOKEN=your_mixpanel_project_token

# Crash reporting — Sentry DSN (public)
# Get from: sentry.io → Project → Settings → Client Keys (DSN)
EXPO_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ─── Edge Function secrets (set via Supabase dashboard, NOT here) ─────────────
# SUPABASE_SERVICE_ROLE_KEY  → Supabase → Project Settings → API → service_role
# GEMINI_API_KEY             → aistudio.google.com → Get API Key
