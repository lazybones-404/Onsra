# ─── Supabase ──────────────────────────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── Google (OAuth + Gemini) ───────────────────────────────────────────────────
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id.apps.googleusercontent.com
# Set on Supabase Edge Functions — not exposed to the app
# GEMINI_API_KEY=your-gemini-api-key

# ─── Sentry ────────────────────────────────────────────────────────────────────
EXPO_PUBLIC_SENTRY_DSN=https://your-key@sentry.io/your-project-id

# ─── Analytics (Mixpanel) ──────────────────────────────────────────────────────
EXPO_PUBLIC_MIXPANEL_TOKEN=your-mixpanel-project-token

# ─── AdMob ─────────────────────────────────────────────────────────────────────
# These are set in app.json plugins, not env vars.
# iOS App ID:     ca-app-pub-XXXX~XXXX
# Android App ID: ca-app-pub-XXXX~XXXX
# Banner unit (iOS):          ca-app-pub-XXXX/XXXX
# Banner unit (Android):      ca-app-pub-XXXX/XXXX
